{
  "description": "modernize-ts - Auto-suggest toolchain upgrades on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/suggest-upgrades.sh"
          }
        ]
      }
    ]
  }
}
